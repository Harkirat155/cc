{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run server)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run check)",
      "Bash(npm test)",
      "Bash(npm test --:*)",
      "Bash(npm test -- *)",
      "Bash(npm run test:*)",
      "Bash(node --check server/*)",
      "Bash(node --version)",
      "Bash(git status)",
      "Bash(git status --:*)",
      "Bash(git diff)",
      "Bash(git diff --:*)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log --:*)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch --:*)",
      "Bash(git remote -v)",
      "Bash(git stash list)",
      "Bash(git rev-parse *)",
      "Bash(git ls-files)",
      "Bash(git ls-files *)",
      "Bash(git blame *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(cat package.json)",
      "Bash(node -e *)"
    ],
    "ask": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npm update *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh issue close *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(git commit --no-verify *)",
      "Bash(npm publish *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)"
    ]
  }
}
