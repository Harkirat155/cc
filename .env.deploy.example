# Copy to .env.deploy and fill provider-specific values locally.
# .env.deploy is ignored by git.

NODE_ENV=production
CORS_ORIGIN=https://harkirat155.github.io
PORT=10000

# Frontend GitHub Pages deploy. BACKEND_URL is baked into the Vite build.
BACKEND_URL=https://crisscross-backend.fly.dev
# VITE_SOCKET_SERVER=https://crisscross-backend.fly.dev
# VITE_API_BASE=https://crisscross-backend.fly.dev
# GH_PAGES_BRANCH=gh-pages
# GH_PAGES_REMOTE=origin
# GH_PAGES_REPO=https://github.com/your-user/your-repo.git
# GH_PAGES_DEST=
# GH_PAGES_MESSAGE=
# GH_PAGES_CNAME=
# GH_PAGES_NO_HISTORY=0
# GH_PAGES_NO_PUSH=0

# Fly.io. Use a globally unique app name.
FLY_APP=crisscross-backend
# FLY_API_TOKEN=
# FLY_USE_LOCAL_AUTH=1

# Railway. Link the project once with `railway link`, or set service name here.
# RAILWAY_API_TOKEN=
# RAILWAY_SERVICE=crisscross-backend
# RAILWAY_PUBLIC_URL=https://your-service.up.railway.app

# Koyeb. This script redeploys an existing Koyeb service source.
# KOYEB_API_TOKEN=
# KOYEB_SERVICE_REF=crisscross-backend/crisscross-backend
# KOYEB_PUBLIC_URL=https://your-service.koyeb.app

# Render paid/no-sleep only. Free services sleep and are not recommended.
# RENDER_SERVICE_ID=
# RENDER_API_KEY=
# RENDER_SERVICE_URL=https://your-service.onrender.com

# Optional feedback sync.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SHEETS_FEEDBACK_RANGE=Feedback!A:E